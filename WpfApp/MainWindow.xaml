<Window x:Class="WpfApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <ComboBox HorizontalAlignment="Left" Margin="37,58,0,0" Name="leftSet"  VerticalAlignment="Top" Width="120" RenderTransformOrigin="-0.639,-0.859" SelectionChanged="ComboBox_SelectionChanged"/>
        <ComboBox HorizontalAlignment="Left" Margin="453,58,0,0" Name="operation"  VerticalAlignment="Top" Width="120"/>
        <ComboBox HorizontalAlignment="Left" Margin="240,58,0,0"  Name="rightSet" VerticalAlignment="Top"   Width="120"/>
        <Button Content="Button" HorizontalAlignment="Left" Margin="672,52,0,0"  VerticalAlignment="Top" Height="34" Width="97"/>
        <ListBox d:ItemsSource="{d:SampleData ItemCount=5}" Margin="26,111,624,39" Name ="rightMembers"  SelectionChanged="ListBox_SelectionChanged"/>
        <ListBox d:ItemsSource="{d:SampleData ItemCount=5}" Margin="423,111,227,39" Name ="leftMembers"/>
        <ListBox d:ItemsSource="{d:SampleData ItemCount=5}" Margin="619,111,31,39" Name="resultSet"/>

    </Grid>
</Window>
